{
  "name": "gitmom",
  "description": "Git desktop helper — branches, commit, search, languages, issues.",
  "author": "Saurabh Rathaur",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^36.8.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.gitmom.desktop",
    "productName": "GitMom",
    "copyright": "Copyright © GitMom",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "forceCodeSigning": false,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
